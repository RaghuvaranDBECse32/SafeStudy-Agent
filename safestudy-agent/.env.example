# SafeStudy Agent - Environment Configuration

# OpenAI API Key (used by Mastra for agents by default)
OPENAI_API_KEY=your_openai_api_key_here

# Alternatively, Gemini API Key if using Gemini models
GEMINI_API_KEY=your_gemini_api_key_here

# Qdrant Database Configuration
# If left empty, the application will fallback to a local mock retrieval system
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# Enkrypt AI Guardrails Configuration
# If left empty, the application will fallback to a local regex-based guardrail moderation system
ENKRYPTAI_API_KEY=your_enkryptai_api_key_here

# Mastra Configuration
MASTRA_TELEMETRY_DISABLED=true
MASTRA_AUTO_REFRESH_PROVIDERS=false
